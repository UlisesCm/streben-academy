# Cloudflare Pages agrega trailing slash automáticamente (308).
# NO agregar reglas que quiten trailing slash — causaría loop de redirects.
# Solo mapeamos rutas legacy de Jimdo (paths distintos) y dejamos que
# CF Pages maneje el trailing slash nativo.

# Rutas legacy Jimdo → nuevas rutas del sitio
/cursos-y-programas          /cursos                301
/cursos-y-programas/         /cursos                301
/cursos-y-programas/*        /cursos/:splat         301
/galeria-y-testimonios       /testimonios           301
/galeria-y-testimonios/      /testimonios           301
/galeria-y-testimonios/*     /testimonios           301
/avisos                      /alumnos               301
/avisos/                     /alumnos               301
/configuracion-de-cookies    /politica-de-privacidad 301
/configuracion-de-cookies/   /politica-de-privacidad 301
