---
import Section from '~/components/ui/Section.astro';
import Container from '~/components/ui/Container.astro';
import Button from '~/components/ui/Button.astro';
import Chip from '~/components/ui/Chip.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import { Users, CalendarDays, Clock, MessageCircle } from 'lucide-astro';
import type { Locale } from '~/i18n/config';
import type { Dictionary } from '~/i18n/strings/es';
import { whatsappLink } from '~/lib/site';

interface Props {
  locale: Locale;
  t: Dictionary;
}

const { t } = Astro.props;
const s = t.students;
const waLink = whatsappLink(t.whatsapp.prefilled);
---

<!-- Hero corto -->
<section class="relative isolate overflow-hidden bg-paper-grid pt-12 sm:pt-20 pb-16 sm:pb-24">
  <!-- Blobs decorativos -->
  <span aria-hidden="true" class="pointer-events-none absolute -left-32 top-8 -z-10 h-72 w-72 rounded-full bg-sage-200/50 blur-3xl dark:bg-sage-700/20"></span>
  <span aria-hidden="true" class="pointer-events-none absolute -right-24 top-16 -z-10 h-64 w-64 rounded-full bg-brand-200/40 blur-3xl dark:bg-brand-700/15"></span>

  <Container size="lg">
    <div class="flex flex-col gap-6">
      <Chip tone="sage" size="md" class="self-start">
        <Users class="h-3.5 w-3.5" aria-hidden="true" />
        {s.eyebrow}
      </Chip>

      <h1 class="font-display text-display-lg text-[color:var(--color-foreground)]">
        {s.title}{' '}
        <span class="wavy-underline-sage">recursos</span>
      </h1>

      <p class="max-w-xl text-lg sm:text-xl text-[color:var(--color-foreground-soft)] leading-relaxed">
        {s.subtitle}
      </p>
    </div>
  </Container>
</section>

<!-- Secciones de contenido -->
<Section tone="default" spacing="lg">
  <Container size="lg">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">

      <!-- Tarjeta 1: Calendario — tono brand -->
      <article
        class="relative flex flex-col gap-6 rounded-2xl border border-[color:var(--color-border)] bg-brand-100/70 p-7 shadow-[var(--shadow-card)] dark:bg-brand-900/30 before:absolute before:inset-x-6 before:top-0 before:h-1 before:rounded-b-full before:bg-brand-400"
      >
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-200/80 dark:bg-brand-700/40">
            <CalendarDays class="h-5 w-5 text-brand-700 dark:text-brand-200" aria-hidden="true" />
          </div>
          <Eyebrow label={s.calendar.title} tone="brand" />
        </div>

        <dl class="flex flex-col divide-y divide-[color:var(--color-border)]">
          {s.calendar.items.map((item) => (
            <div class="flex flex-col gap-1 py-4 first:pt-0 last:pb-0">
              <dt class="text-xs uppercase tracking-[0.16em] text-[color:var(--color-foreground-muted)] font-semibold">
                {item.label}
              </dt>
              <dd class="font-display text-xl text-[color:var(--color-foreground)]">
                {item.value}
              </dd>
            </div>
          ))}
        </dl>
      </article>

      <!-- Tarjeta 2: Horarios — tono peach -->
      <article
        class="relative flex flex-col gap-6 rounded-2xl border border-[color:var(--color-border)] bg-peach-100/70 p-7 shadow-[var(--shadow-card)] dark:bg-peach-700/20 before:absolute before:inset-x-6 before:top-0 before:h-1 before:rounded-b-full before:bg-peach-300"
      >
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-peach-200/80 dark:bg-peach-700/40">
            <Clock class="h-5 w-5 text-peach-700 dark:text-peach-200" aria-hidden="true" />
          </div>
          <Eyebrow label={s.schedules.title} tone="peach" />
        </div>

        <p class="text-base text-[color:var(--color-foreground-soft)] leading-relaxed">
          {s.schedules.body}
        </p>
      </article>

      <!-- Tarjeta 3: Contacto rápido — tono sage -->
      <article
        class="relative flex flex-col gap-6 rounded-2xl border border-[color:var(--color-border)] bg-sage-100/70 p-7 shadow-[var(--shadow-card)] dark:bg-sage-700/20 before:absolute before:inset-x-6 before:top-0 before:h-1 before:rounded-b-full before:bg-sage-300"
      >
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-sage-200/80 dark:bg-sage-700/40">
            <MessageCircle class="h-5 w-5 text-sage-700 dark:text-sage-200" aria-hidden="true" />
          </div>
          <Eyebrow label={s.contact.title} tone="sage" />
        </div>

        <p class="text-base text-[color:var(--color-foreground-soft)] leading-relaxed">
          {s.contact.body}
        </p>

        <div class="mt-auto">
          <Button
            href={waLink}
            variant="whatsapp"
            size="md"
            target="_blank"
            rel="noopener noreferrer"
          >
            <MessageCircle class="h-4 w-4" aria-hidden="true" />
            <span>Escribir por WhatsApp</span>
          </Button>
        </div>
      </article>

    </div>
  </Container>
</Section>
