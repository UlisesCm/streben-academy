---
import Hero from '~/components/sections/Hero.astro';
import Marquee from '~/components/sections/Marquee.astro';
import Intro from '~/components/sections/Intro.astro';
import Benefits from '~/components/sections/Benefits.astro';
import Programs from '~/components/sections/Programs.astro';
import Scholarships from '~/components/sections/Scholarships.astro';
import Testimonials from '~/components/sections/Testimonials.astro';
import FinalCta from '~/components/sections/FinalCta.astro';
import type { Locale } from '~/i18n/config';
import type { Dictionary } from '~/i18n/strings/es';

interface Props {
  locale: Locale;
  t: Dictionary;
}

const { locale, t } = Astro.props;
---

<Hero locale={locale} t={t} />
<Marquee words={t.home.marquee.words} tone="ink" />
<Intro t={t} />
<Benefits t={t} />
<Programs locale={locale} t={t} />
<Scholarships locale={locale} t={t} />
<Testimonials locale={locale} t={t} />
<FinalCta locale={locale} t={t} />
