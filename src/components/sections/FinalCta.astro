---
import Container from '~/components/ui/Container.astro';
import Button from '~/components/ui/Button.astro';
import { ArrowUpRight, MessageCircle, FileCheck } from 'lucide-astro';
import type { Locale } from '~/i18n/config';
import type { Dictionary } from '~/i18n/strings/es';
import { whatsappLink, FORMS } from '~/lib/site';

interface Props {
  locale: Locale;
  t: Dictionary;
}

const { t } = Astro.props;
const c = t.home.finalCta;
const waLink = whatsappLink(t.whatsapp.prefilled);
---

<section class="relative isolate overflow-hidden bg-[color:var(--color-ink)] py-24 sm:py-32 text-[color:var(--color-paper)]">
  <!-- Decorative shapes -->
  <span aria-hidden="true" class="pointer-events-none absolute -left-32 -top-32 h-96 w-96 rounded-full bg-brand-500/40 blur-3xl"></span>
  <span aria-hidden="true" class="pointer-events-none absolute -right-24 bottom-0 h-80 w-80 rounded-full bg-peach-400/25 blur-3xl"></span>
  <span aria-hidden="true" class="pointer-events-none absolute left-1/2 top-1/3 h-64 w-64 -translate-x-1/2 rounded-full bg-sage-400/15 blur-3xl"></span>

  <Container size="lg" class="relative">
    <div class="flex flex-col items-center text-center gap-8">
      <div class="flex items-center gap-3 text-eyebrow uppercase font-semibold text-[color:var(--color-paper)]/55">
        <span class="font-display font-normal text-base text-peach-300">06</span>
        <span aria-hidden="true" class="block h-px w-8 bg-[color:var(--color-paper)]/20"></span>
        <span class="tracking-[0.16em]">{c.eyebrow.split('—')[1]?.trim() ?? c.eyebrow}</span>
      </div>

      <h2 class="font-display text-display-lg max-w-3xl text-[color:var(--color-paper)]">
        {c.title}{' '}
        <span class="wavy-underline-peach">{c.titleAccent}</span>{c.titleEnd}
      </h2>

      <p class="max-w-xl text-lg text-[color:var(--color-paper)]/75 leading-relaxed">
        {c.subtitle}
      </p>

      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        <Button href={waLink} variant="whatsapp" size="lg">
          <MessageCircle class="h-5 w-5" aria-hidden="true" />
          <span>{c.ctaPrimary}</span>
        </Button>
        <a
          href={FORMS.examenColocacion}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-14 items-center gap-2 rounded-full border border-white/20 bg-white/5 px-7 text-base font-semibold text-[color:var(--color-paper)] transition-colors hover:bg-white/10 focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-3"
        >
          <FileCheck class="h-5 w-5" aria-hidden="true" />
          <span>{c.ctaSecondary}</span>
          <ArrowUpRight class="h-4 w-4" aria-hidden="true" />
        </a>
      </div>
    </div>
  </Container>
</section>
