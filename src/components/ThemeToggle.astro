---
import { Sun, Moon, Monitor } from 'lucide-astro';

interface Props {
  labels: {
    menu: string;
    light: string;
    dark: string;
    system: string;
  };
  /** Where the dropdown opens relative to the trigger. Use a `top-*` value when the
   *  trigger sits near the bottom of its container (e.g. inside the mobile sheet). */
  placement?: 'bottom-end' | 'top-start' | 'top-end';
}

const { labels, placement = 'bottom-end' } = Astro.props;

const placementClasses: Record<NonNullable<Props['placement']>, string> = {
  'bottom-end': 'right-0 top-12 origin-top-right',
  'top-start': 'left-0 bottom-12 origin-bottom-left',
  'top-end': 'right-0 bottom-12 origin-bottom-right',
};
---

<div class="relative" data-theme-root>
  <button
    type="button"
    data-theme-trigger
    aria-label={labels.menu}
    aria-haspopup="menu"
    aria-expanded="false"
    class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] text-[color:var(--color-foreground-soft)] transition-colors hover:bg-brand-50 hover:text-[color:var(--color-foreground)] focus-visible:outline-2 focus-visible:outline-[color:var(--color-ring)] focus-visible:outline-offset-3 dark:hover:bg-brand-900/30"
  >
    <Sun class="h-[18px] w-[18px] hidden [.theme-light_&]:block" aria-hidden="true" />
    <Moon class="h-[18px] w-[18px] hidden [.theme-dark_&]:block" aria-hidden="true" />
    <Monitor class="h-[18px] w-[18px] hidden [.theme-system_&]:block" aria-hidden="true" />
    <Sun class="h-[18px] w-[18px] [.theme-light_&]:hidden [.theme-dark_&]:hidden [.theme-system_&]:hidden" aria-hidden="true" />
  </button>

  <div
    data-theme-menu
    role="menu"
    aria-label={labels.menu}
    class:list={[
      'invisible absolute z-40 min-w-[180px] scale-95 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface-elevated)] p-1.5 opacity-0 shadow-[var(--shadow-pop)] transition-[transform,opacity,visibility] duration-200 ease-out data-[open=true]:visible data-[open=true]:scale-100 data-[open=true]:opacity-100',
      placementClasses[placement],
    ]}
  >
    <button
      type="button"
      role="menuitemradio"
      data-theme-value="light"
      class="flex w-full items-center gap-2.5 rounded-lg px-3 py-2 text-sm font-medium text-[color:var(--color-foreground-soft)] transition-colors hover:bg-brand-50 hover:text-[color:var(--color-foreground)] aria-checked:bg-brand-100 aria-checked:text-[color:var(--color-foreground)] dark:hover:bg-brand-900/30 dark:aria-checked:bg-brand-800/40"
    >
      <Sun class="h-4 w-4" aria-hidden="true" />
      <span>{labels.light}</span>
    </button>
    <button
      type="button"
      role="menuitemradio"
      data-theme-value="dark"
      class="flex w-full items-center gap-2.5 rounded-lg px-3 py-2 text-sm font-medium text-[color:var(--color-foreground-soft)] transition-colors hover:bg-brand-50 hover:text-[color:var(--color-foreground)] aria-checked:bg-brand-100 aria-checked:text-[color:var(--color-foreground)] dark:hover:bg-brand-900/30 dark:aria-checked:bg-brand-800/40"
    >
      <Moon class="h-4 w-4" aria-hidden="true" />
      <span>{labels.dark}</span>
    </button>
    <button
      type="button"
      role="menuitemradio"
      data-theme-value="system"
      class="flex w-full items-center gap-2.5 rounded-lg px-3 py-2 text-sm font-medium text-[color:var(--color-foreground-soft)] transition-colors hover:bg-brand-50 hover:text-[color:var(--color-foreground)] aria-checked:bg-brand-100 aria-checked:text-[color:var(--color-foreground)] dark:hover:bg-brand-900/30 dark:aria-checked:bg-brand-800/40"
    >
      <Monitor class="h-4 w-4" aria-hidden="true" />
      <span>{labels.system}</span>
    </button>
  </div>
</div>

<script>
  type ThemePref = 'light' | 'dark' | 'system';
  const STORAGE_KEY = 'streben-theme';

  function currentPref(): ThemePref {
    return (localStorage.getItem(STORAGE_KEY) as ThemePref | null) ?? 'system';
  }

  function applyTheme(pref: ThemePref) {
    const root = document.documentElement;
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = pref === 'dark' || (pref === 'system' && systemDark);
    root.classList.toggle('dark', isDark);
    root.classList.toggle('theme-light', pref === 'light');
    root.classList.toggle('theme-dark', pref === 'dark');
    root.classList.toggle('theme-system', pref === 'system');
    root.dataset.theme = pref;
  }

  function updateMenuMarks(pref: ThemePref) {
    document.querySelectorAll<HTMLButtonElement>('[data-theme-value]').forEach((btn) => {
      btn.setAttribute('aria-checked', btn.dataset.themeValue === pref ? 'true' : 'false');
    });
  }

  function initThemeToggle() {
    const pref = currentPref();
    applyTheme(pref);
    updateMenuMarks(pref);

    document.querySelectorAll<HTMLElement>('[data-theme-root]').forEach((root) => {
      const trigger = root.querySelector<HTMLButtonElement>('[data-theme-trigger]');
      const menu = root.querySelector<HTMLElement>('[data-theme-menu]');
      if (!trigger || !menu) return;

      const close = () => {
        menu.dataset.open = 'false';
        trigger.setAttribute('aria-expanded', 'false');
      };
      const open = () => {
        menu.dataset.open = 'true';
        trigger.setAttribute('aria-expanded', 'true');
      };

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        if (menu.dataset.open === 'true') close();
        else open();
      });

      menu.querySelectorAll<HTMLButtonElement>('[data-theme-value]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const value = btn.dataset.themeValue as ThemePref;
          localStorage.setItem(STORAGE_KEY, value);
          applyTheme(value);
          updateMenuMarks(value);
          close();
        });
      });

      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    });

    // Respond to OS theme changes when in "system" mode
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      if (currentPref() === 'system') applyTheme('system');
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
