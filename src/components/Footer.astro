---
import Container from './ui/Container.astro';
import Logo from './Logo.astro';
import { Facebook, Instagram, MessageCircle, Mail, Phone, ArrowUpRight } from 'lucide-astro';
import type { Locale } from '~/i18n/config';
import type { Dictionary } from '~/i18n/strings/es';
import { loc } from '~/lib/url';
import { CONTACT, SOCIAL, SITE, whatsappLink, mailtoLink } from '~/lib/site';

interface Props {
  locale: Locale;
  t: Dictionary;
}

const { locale, t } = Astro.props;
const year = 2026;

const navColumns = [
  {
    title: t.footer.navTitle,
    items: [
      { href: loc(locale, ''), label: t.nav.home },
      { href: loc(locale, 'sobre-nosotros'), label: t.nav.about },
      { href: loc(locale, 'becas'), label: t.nav.scholarships },
      { href: loc(locale, 'testimonios'), label: t.nav.testimonials },
      { href: loc(locale, 'galeria'), label: t.nav.gallery },
      { href: loc(locale, 'alumnos'), label: t.nav.students },
    ],
  },
  {
    title: t.footer.coursesTitle,
    items: [
      { href: loc(locale, 'cursos#kiddos'), label: t.home.programs.kiddos.name },
      { href: loc(locale, 'cursos#teens'), label: t.home.programs.teens.name },
      { href: loc(locale, 'cursos#adults'), label: t.home.programs.adults.name },
      { href: loc(locale, 'cursos#tutoring'), label: t.home.programs.tutoring.name },
    ],
  },
  {
    title: t.footer.legalTitle,
    items: [
      { href: loc(locale, 'aviso-legal'), label: t.legal.terms.title },
      { href: loc(locale, 'politica-de-privacidad'), label: t.legal.privacy.title },
    ],
  },
];

const waLink = whatsappLink(t.whatsapp.prefilled);
const emailLink = mailtoLink();
---

<footer class="relative isolate overflow-hidden bg-[color:var(--color-ink)] text-[color:var(--color-paper)]">
  <span aria-hidden="true" class="pointer-events-none absolute -right-32 -top-32 h-80 w-80 rounded-full bg-brand-600/30 blur-3xl"></span>
  <span aria-hidden="true" class="pointer-events-none absolute -left-32 bottom-0 h-80 w-80 rounded-full bg-peach-500/15 blur-3xl"></span>

  <Container size="xl" class="relative py-16 sm:py-24">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
      <!-- Brand block -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <Logo class="text-[color:var(--color-paper)]" />
        <p class="text-[color:var(--color-paper)]/70 text-base leading-relaxed max-w-sm">
          {t.footer.description}
        </p>
        <p class="font-display text-2xl text-brand-200">
          {t.footer.tagline}
        </p>
        <div class="flex items-center gap-3">
          <a
            href={SOCIAL.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-[color:var(--color-paper)] transition-colors hover:bg-white/15"
          >
            <Facebook class="h-4 w-4" aria-hidden="true" />
          </a>
          <a
            href={SOCIAL.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-[color:var(--color-paper)] transition-colors hover:bg-white/15"
          >
            <Instagram class="h-4 w-4" aria-hidden="true" />
          </a>
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-[color:var(--color-paper)] transition-colors hover:bg-white/15"
          >
            <MessageCircle class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>
      </div>

      <!-- Link columns -->
      <div class="lg:col-span-7 grid grid-cols-2 gap-8 sm:grid-cols-3">
        {navColumns.map((col) => (
          <div>
            <h3 class="font-display text-sm text-[color:var(--color-paper)] mb-4">
              {col.title}
            </h3>
            <ul class="flex flex-col gap-2.5">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-sm text-[color:var(--color-paper)]/65 transition-colors hover:text-[color:var(--color-paper)]"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Contact strip -->
    <div class="mt-16 grid grid-cols-1 gap-4 rounded-3xl border border-white/10 bg-white/[0.04] p-6 sm:grid-cols-3 sm:p-8">
      <a
        href={waLink}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-start gap-4 rounded-2xl p-3 transition-colors hover:bg-white/5"
      >
        <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-500/20 text-brand-200">
          <MessageCircle class="h-4 w-4" aria-hidden="true" />
        </span>
        <span class="flex flex-col">
          <span class="text-xs uppercase tracking-[0.16em] text-[color:var(--color-paper)]/50">WhatsApp</span>
          <span class="font-display text-lg text-[color:var(--color-paper)]">
            {CONTACT.whatsappDisplay}
          </span>
        </span>
      </a>
      <a
        href={`tel:+52${CONTACT.phone}`}
        class="group flex items-start gap-4 rounded-2xl p-3 transition-colors hover:bg-white/5"
      >
        <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-peach-500/25 text-peach-200">
          <Phone class="h-4 w-4" aria-hidden="true" />
        </span>
        <span class="flex flex-col">
          <span class="text-xs uppercase tracking-[0.16em] text-[color:var(--color-paper)]/50">{t.contactPage.direct.phoneLabel}</span>
          <span class="font-display text-lg text-[color:var(--color-paper)]">
            {CONTACT.whatsappDisplay}
          </span>
        </span>
      </a>
      <a
        href={emailLink}
        class="group flex items-start gap-4 rounded-2xl p-3 transition-colors hover:bg-white/5"
      >
        <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-sage-500/25 text-sage-200">
          <Mail class="h-4 w-4" aria-hidden="true" />
        </span>
        <span class="flex flex-col">
          <span class="text-xs uppercase tracking-[0.16em] text-[color:var(--color-paper)]/50">{t.contactPage.direct.emailLabel}</span>
          <span class="font-display text-base text-[color:var(--color-paper)] break-all">
            {CONTACT.email}
          </span>
        </span>
      </a>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-white/10 pt-6 sm:flex-row sm:items-center">
      <p class="text-xs text-[color:var(--color-paper)]/55">
        © {year} {SITE.name}. {t.footer.rightsReserved}
      </p>
      <p class="text-xs text-[color:var(--color-paper)]/55">
        {t.footer.builtWith}
      </p>
    </div>
  </Container>
</footer>
