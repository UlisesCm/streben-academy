---
interface Props {
  tone?: 'default' | 'alt' | 'ink' | 'brand' | 'peach' | 'sage' | 'butter';
  spacing?: 'sm' | 'md' | 'lg' | 'xl';
  id?: string;
  class?: string;
  decorative?: boolean;
}

const {
  tone = 'default',
  spacing = 'lg',
  id,
  class: className = '',
  decorative = false,
} = Astro.props;

const bg: Record<NonNullable<Props['tone']>, string> = {
  default: 'bg-[color:var(--color-surface)] text-[color:var(--color-foreground)]',
  alt: 'bg-[color:var(--color-surface-2)] text-[color:var(--color-foreground)]',
  ink: 'bg-[color:var(--color-ink)] text-[color:var(--color-paper)]',
  brand: 'bg-brand-100/70 text-[color:var(--color-ink)] dark:bg-brand-900/40 dark:text-[color:var(--color-paper)]',
  peach: 'bg-peach-100/70 text-[color:var(--color-ink)] dark:bg-peach-700/20 dark:text-[color:var(--color-paper)]',
  sage:  'bg-sage-100/70 text-[color:var(--color-ink)] dark:bg-sage-700/20 dark:text-[color:var(--color-paper)]',
  butter:'bg-butter-100/70 text-[color:var(--color-ink)] dark:bg-butter-700/20 dark:text-[color:var(--color-paper)]',
};

const pad: Record<NonNullable<Props['spacing']>, string> = {
  sm: 'py-12 sm:py-16',
  md: 'py-16 sm:py-20',
  lg: 'py-20 sm:py-24 lg:py-28',
  xl: 'py-24 sm:py-32 lg:py-40',
};
---

<section
  id={id}
  class:list={[
    'relative isolate overflow-hidden',
    bg[tone],
    pad[spacing],
    className,
  ]}
>
  {
    decorative && (
      <>
        <span
          aria-hidden="true"
          class="pointer-events-none absolute -left-24 top-1/3 -z-10 h-72 w-72 rounded-full bg-peach-200/60 blur-3xl dark:bg-peach-700/15"
        />
        <span
          aria-hidden="true"
          class="pointer-events-none absolute -right-24 bottom-0 -z-10 h-80 w-80 rounded-full bg-brand-200/60 blur-3xl dark:bg-brand-800/30"
        />
      </>
    )
  }
  <slot />
</section>
