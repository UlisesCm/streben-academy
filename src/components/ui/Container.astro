---
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  class?: string;
}

const { size = 'lg', class: className = '' } = Astro.props;

const widths: Record<NonNullable<Props['size']>, string> = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-6xl',
  xl: 'max-w-7xl',
  full: 'max-w-none',
};
---

<div class:list={['mx-auto w-full px-5 sm:px-7 lg:px-10', widths[size], className]}>
  <slot />
</div>
