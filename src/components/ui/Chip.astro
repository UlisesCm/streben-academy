---
interface Props {
  tone?: 'brand' | 'peach' | 'sage' | 'butter' | 'outline';
  size?: 'sm' | 'md';
  class?: string;
}

const { tone = 'brand', size = 'md', class: className = '' } = Astro.props;

const tones: Record<NonNullable<Props['tone']>, string> = {
  brand:
    'bg-brand-200/60 text-brand-800 border-brand-300/60 dark:bg-brand-700/25 dark:text-brand-100 dark:border-brand-500/30',
  peach:
    'bg-peach-200/60 text-peach-700 border-peach-300/60 dark:bg-peach-700/25 dark:text-peach-100 dark:border-peach-500/30',
  sage:
    'bg-sage-200/60 text-sage-700 border-sage-300/60 dark:bg-sage-700/25 dark:text-sage-100 dark:border-sage-500/30',
  butter:
    'bg-butter-200/60 text-butter-700 border-butter-300/60 dark:bg-butter-700/25 dark:text-butter-100 dark:border-butter-500/30',
  outline:
    'bg-transparent text-[color:var(--color-foreground-soft)] border-[color:var(--color-border)]',
};

const sizes: Record<NonNullable<Props['size']>, string> = {
  sm: 'px-2.5 py-1 text-[11px]',
  md: 'px-3 py-1.5 text-xs sm:text-[13px]',
};
---

<span
  class:list={[
    'inline-flex items-center gap-1.5 rounded-full border font-medium',
    tones[tone],
    sizes[size],
    className,
  ]}
>
  <slot />
</span>
