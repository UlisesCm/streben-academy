---
import BaseLayout from '~/layouts/BaseLayout.astro';
import AlumnosPage from '~/components/pages/AlumnosPage.astro';
import { localePaths } from '~/i18n/config';
import { useTranslations, type Locale } from '~/i18n';

export const getStaticPaths = () => localePaths();

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const t = useTranslations(locale);
---

<BaseLayout
  locale={locale}
  title={`${t.students.title} ${t.students.titleAccent} | STREBEN ACADEMY`}
  description={t.students.subtitle}
>
  <AlumnosPage locale={locale} t={t} />
</BaseLayout>
