---
import BaseLayout from '~/layouts/BaseLayout.astro';
import GaleriaPage from '~/components/pages/GaleriaPage.astro';
import { localePaths } from '~/i18n/config';
import { useTranslations, type Locale } from '~/i18n';

export const getStaticPaths = () => localePaths();

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const t = useTranslations(locale);
---

<BaseLayout
  locale={locale}
  title={`${t.gallery.title} ${t.gallery.titleAccent} | STREBEN ACADEMY`}
  description={t.gallery.subtitle}
>
  <GaleriaPage locale={locale} t={t} />
</BaseLayout>
