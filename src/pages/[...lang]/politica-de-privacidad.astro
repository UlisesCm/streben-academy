---
import BaseLayout from '~/layouts/BaseLayout.astro';
import LegalPage from '~/components/pages/LegalPage.astro';
import { localePaths } from '~/i18n/config';
import { useTranslations, type Locale } from '~/i18n';

export const getStaticPaths = () => localePaths();

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const t = useTranslations(locale);
const privacy = t.legal.privacy;
---

<BaseLayout
  locale={locale}
  title={`${privacy.title} | STREBEN ACADEMY`}
  description={privacy.body[0]}
  noindex={true}
>
  <LegalPage
    title={privacy.title}
    lastUpdate={privacy.lastUpdate}
    body={privacy.body}
  />
</BaseLayout>
